# Copiá este archivo a .env.local y ajustá los valores.
#
# URL base de la API (incluye el prefijo /api/v1).
# Dejala COMENTADA para desarrollo local: src/shared/api/client.ts detecta
# automáticamente la IP de la máquina (via Expo hostUri), así el celular
# físico llega al backend sin configurar nada.
# Descomentala solo para apuntar a un backend remoto (ej: Render).
# EXPO_PUBLIC_API_URL=https://depaso-api.onrender.com/api/v1
