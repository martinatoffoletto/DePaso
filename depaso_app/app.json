{
  "expo": {
    "name": "depaso_app",
    "slug": "depaso_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/DePaso_icon.png",
    "scheme": "depasoapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.depaso.app",
      "adaptiveIcon": {
        "backgroundColor": "#2A7A4B",
        "foregroundImage": "./assets/images/DePaso_icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/DePaso_icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2A7A4B",
          "dark": {
            "backgroundColor": "#2A7A4B"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
