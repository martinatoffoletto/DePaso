# Database
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/depaso_dev

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Server
DEBUG=True
ENVIRONMENT=development

# API
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081","http://localhost:8100"]

# Rate limiting (set to false in tests via RATE_LIMIT_ENABLED=false)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH=5/minute

# AI Models
VISION_MODEL_PATH=./ml/models/cargo_classifier_v1.keras
CONFIDENCE_THRESHOLD=0.7

# External APIs
OSRM_URL=http://router.project-osrm.org
IPCC_EMISSION_FACTOR_DEFAULT=0.2
